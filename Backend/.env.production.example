# ========================================
# COOKIES CAFE - PRODUCTION ENVIRONMENT
# ========================================

# Server Configuration
NODE_ENV=production
PORT=5001

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host.supabase.co:5432/database

# JWT Configuration (GENERATE STRONG SECRET!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_256_bit_secret_key_here_generate_new_one
JWT_EXPIRE=7d

# Stripe Payment (PRODUCTION KEYS!)
STRIPE_SECRET_KEY=sk_live_your_live_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenAI Configuration (PRODUCTION KEY!)
OPENAI_API_KEY=sk-your_production_openai_key

# Cloudinary Configuration (PRODUCTION)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (PRODUCTION SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@cookiescafe.com

# Frontend URL (PRODUCTION)
FRONTEND_URL=https://cookiescafe.com

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Session Configuration
SESSION_SECRET=your_session_secret_generate_new_one

# CORS Configuration
CORS_ORIGIN=https://cookiescafe.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# API Rate Limiting
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=5
PAYMENT_RATE_LIMIT=10

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_ITEMS=1000

# WebSocket Configuration
SOCKET_CORS_ORIGIN=https://cookiescafe.com

# Monitoring
ENABLE_MONITORING=true
HEALTH_CHECK_INTERVAL=60000

# Performance
ENABLE_COMPRESSION=true
ENABLE_CACHE=true

# Feature Flags
ENABLE_AI_CHATBOT=true
ENABLE_VOICE_ORDERING=true
ENABLE_STORIES=true
ENABLE_CUSTOMIZATION=true
ENABLE_LOYALTY_PROGRAM=true
ENABLE_QR_ORDERING=true

# External Services
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing maintenance. Please check back soon.
