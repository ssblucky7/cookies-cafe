# ========================================
# COOKIES CAFE FRONTEND - PRODUCTION
# ========================================

# API Configuration
VITE_API_URL=https://api.cookiescafe.com

# Stripe Configuration (PRODUCTION)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key

# WebSocket Configuration
VITE_SOCKET_URL=https://api.cookiescafe.com

# Application Metadata
VITE_APP_NAME=Cookies Cafe
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Premium Handcrafted Cookies & Cafe

# Feature Flags
VITE_ENABLE_AI_CHATBOT=true
VITE_ENABLE_VOICE_ORDERING=true
VITE_ENABLE_STORIES=true
VITE_ENABLE_CUSTOMIZATION=true
VITE_ENABLE_LOYALTY_PROGRAM=true
VITE_ENABLE_QR_ORDERING=true

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_FACEBOOK_PIXEL_ID=

# Social Media Links
VITE_FACEBOOK_URL=https://facebook.com/cookiescafe
VITE_INSTAGRAM_URL=https://instagram.com/cookiescafe
VITE_TWITTER_URL=https://twitter.com/cookiescafe

# Contact Information
VITE_CONTACT_EMAIL=info@cookiescafe.com
VITE_CONTACT_PHONE=+1234567890
VITE_CONTACT_ADDRESS=123 Cookie Street, Cafe City, CC 12345

# Business Hours
VITE_BUSINESS_HOURS_WEEKDAY=8:00 AM - 10:00 PM
VITE_BUSINESS_HOURS_WEEKEND=9:00 AM - 11:00 PM

# Map Configuration
VITE_MAP_LAT=40.7484
VITE_MAP_LNG=-73.9875

# SEO Configuration
VITE_SEO_TITLE=Cookies Cafe - Premium Handcrafted Cookies
VITE_SEO_DESCRIPTION=Experience the finest handcrafted cookies and beverages at Cookies Cafe
VITE_SEO_KEYWORDS=cookies, cafe, bakery, handcrafted, premium

# Performance
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true

# Security
VITE_ENABLE_HTTPS_ONLY=true
